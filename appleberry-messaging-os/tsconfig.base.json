{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@appleberry/types": [
        "packages/types/src"
      ],
      "@appleberry/config": [
        "packages/config/src"
      ],
      "@appleberry/ui": [
        "packages/ui/src"
      ]
    }
  }
}
