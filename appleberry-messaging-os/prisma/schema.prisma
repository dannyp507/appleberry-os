generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GlobalRole {
  SUPER_ADMIN
  WORKSPACE_OWNER
  MANAGER
  AGENT
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum ProviderType {
  CLOUD_API
  WHATSAPP_WEB
  FUTURE_PROVIDER
}

enum WhatsappAccountStatus {
  ACTIVE
  PAUSED
  DISCONNECTED
  ARCHIVED
}

enum SessionStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  RECONNECTING
  EXPIRED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum CampaignRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
  SKIPPED
  INVALID
  OPTED_OUT
  DUPLICATE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum TemplateType {
  TEXT
  MEDIA
  BUTTON
  LIST
  PROMO
  SUPPORT
  FOLLOW_UP
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FlowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FlowNodeType {
  TRIGGER
  SEND_TEXT
  SEND_MEDIA
  SEND_BUTTONS
  SEND_LIST
  ASK_QUESTION
  SAVE_ANSWER
  CONDITION
  KEYWORD_ROUTER
  TAG_CONTACT
  ASSIGN_AGENT
  DELAY
  CALL_WEBHOOK
  AI_REPLY
  HUMAN_HANDOFF
  END
}

enum InboxThreadStatus {
  OPEN
  PENDING
  CLOSED
  BOT_ACTIVE
}

enum ApiKeyScope {
  ACCOUNT_READ
  ACCOUNT_WRITE
  MESSAGE_SEND
  CONTACT_READ
  CONTACT_WRITE
  CAMPAIGN_WRITE
  ANALYTICS_READ
  FLOW_EXECUTE
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String?
  firstName       String
  lastName        String
  globalRole      GlobalRole      @default(VIEWER)
  isPlatformOwner Boolean         @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  memberships     Membership[]
  apiKeys         ApiKey[]
  assignedContacts Contact[]      @relation("AssignedContacts")
  assignedThreads InboxThread[]   @relation("AssignedThreads")
  activityLogs    ActivityLog[]
  auditLogs       AuditLog[]
}

model Organization {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  workspaces      Workspace[]
  subscriptions   Subscription[]
  billingEvents   BillingEvent[]
}

model Workspace {
  id                  String               @id @default(cuid())
  organizationId      String
  name                String
  slug                String
  status              WorkspaceStatus      @default(ACTIVE)
  timezone            String               @default("UTC")
  locale              String               @default("en")
  brandingConfig      Json?
  settings            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  organization        Organization         @relation(fields: [organizationId], references: [id])
  memberships         Membership[]
  whatsappAccounts    WhatsappAccount[]
  contacts            Contact[]
  contactGroups       ContactGroup[]
  tags                Tag[]
  campaigns           Campaign[]
  templates           Template[]
  chatbotFlows        ChatbotFlow[]
  autoresponderRules  AutoresponderRule[]
  fallbackRules       FallbackRule[]
  inboxThreads        InboxThread[]
  messageLogs         MessageLog[]
  apiKeys             ApiKey[]
  imports             ImportJob[]
  exports             ExportJob[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  @@unique([organizationId, slug])
}

model Membership {
  id           String           @id @default(cuid())
  userId       String
  workspaceId  String
  role         GlobalRole
  status       MembershipStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id])
  workspace    Workspace        @relation(fields: [workspaceId], references: [id])
  @@unique([userId, workspaceId])
}

model Plan {
  id                 String         @id @default(cuid())
  code               String         @unique
  name               String
  maxWhatsappAccounts Int
  maxCampaignsPerMonth Int
  maxContacts        Int
  maxFlows           Int
  maxApiRequests     Int
  maxMonthlyMessages Int
  features           Json
  subscriptions      Subscription[]
}

model Subscription {
  id             String        @id @default(cuid())
  organizationId String
  planId         String
  status         String
  periodStart    DateTime
  periodEnd      DateTime
  workspaceLimitOverride Json?
  organization   Organization  @relation(fields: [organizationId], references: [id])
  plan           Plan          @relation(fields: [planId], references: [id])
}

model WhatsappAccount {
  id                  String                @id @default(cuid())
  workspaceId         String
  name                String
  providerType        ProviderType
  phoneNumber         String?
  status              WhatsappAccountStatus @default(ACTIVE)
  sessionStatus       SessionStatus         @default(PENDING)
  healthScore         Int                   @default(100)
  qualityRating       String?
  lastSyncAt          DateTime?
  dailySendCount      Int                   @default(0)
  monthlySendCount    Int                   @default(0)
  webhookStatus       String?
  reconnectStatus     String?
  encryptedCredentials Json?
  rateLimitConfig     Json?
  sendingPolicy       Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?
  workspace           Workspace             @relation(fields: [workspaceId], references: [id])
  sessions            WhatsappSession[]
  campaigns           Campaign[]
  messageLogs         MessageLog[]
  inboxThreads        InboxThread[]
}

model WhatsappSession {
  id                String        @id @default(cuid())
  whatsappAccountId String
  status            SessionStatus @default(PENDING)
  qrCodeUrl         String?
  sessionBlob       Json?
  lastHeartbeatAt   DateTime?
  lastError         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  account           WhatsappAccount @relation(fields: [whatsappAccountId], references: [id])
}

model Contact {
  id                 String       @id @default(cuid())
  workspaceId        String
  assignedAgentId    String?
  firstName          String?
  lastName           String?
  fullName           String?
  phoneNumber        String
  email              String?
  city               String?
  notes              String?
  source             String?
  customFields       Json?
  optInStatus        Boolean      @default(false)
  optOutStatus       Boolean      @default(false)
  consentTimestamp   DateTime?
  lastContactedAt    DateTime?
  lastRepliedAt      DateTime?
  leadStage          String?
  conversationStatus String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?
  workspace          Workspace    @relation(fields: [workspaceId], references: [id])
  assignedAgent      User?        @relation("AssignedContacts", fields: [assignedAgentId], references: [id])
  groupMembers       ContactGroupMember[]
  tags               ContactTag[]
  messageLogs        MessageLog[]
  campaignRecipients CampaignRecipient[]
  inboxThreads       InboxThread[]
  @@index([workspaceId, phoneNumber])
}

model ContactGroup {
  id            String              @id @default(cuid())
  workspaceId   String
  name          String
  description   String?
  dynamicFilter Json?
  isDynamic     Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  workspace     Workspace           @relation(fields: [workspaceId], references: [id])
  members       ContactGroupMember[]
}

model ContactGroupMember {
  id             String       @id @default(cuid())
  contactId      String
  contactGroupId String
  createdAt      DateTime     @default(now())
  contact        Contact      @relation(fields: [contactId], references: [id])
  contactGroup   ContactGroup @relation(fields: [contactGroupId], references: [id])
  @@unique([contactId, contactGroupId])
}

model Tag {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  color       String?
  createdAt   DateTime     @default(now())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  contacts    ContactTag[]
}

model ContactTag {
  id        String   @id @default(cuid())
  contactId String
  tagId     String
  contact   Contact  @relation(fields: [contactId], references: [id])
  tag       Tag      @relation(fields: [tagId], references: [id])
  @@unique([contactId, tagId])
}

model Campaign {
  id                  String          @id @default(cuid())
  workspaceId         String
  whatsappAccountId   String?
  templateId          String?
  name                String
  description         String?
  status              CampaignStatus  @default(DRAFT)
  scheduleAt          DateTime?
  timezone            String?
  accountRotation     Boolean         @default(false)
  sendWindowConfig    Json?
  throttlingConfig    Json?
  personalizationMap  Json?
  targetingConfig     Json?
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  workspace           Workspace       @relation(fields: [workspaceId], references: [id])
  whatsappAccount     WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])
  template            Template?       @relation(fields: [templateId], references: [id])
  recipients          CampaignRecipient[]
  events              CampaignEvent[]
}

model CampaignRecipient {
  id           String                  @id @default(cuid())
  campaignId   String
  contactId    String
  status       CampaignRecipientStatus @default(PENDING)
  errorCode    String?
  errorMessage String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  repliedAt    DateTime?
  campaign     Campaign                @relation(fields: [campaignId], references: [id])
  contact      Contact                 @relation(fields: [contactId], references: [id])
  @@unique([campaignId, contactId])
}

model CampaignEvent {
  id          String    @id @default(cuid())
  campaignId  String
  type        String
  payload     Json
  occurredAt  DateTime  @default(now())
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
}

model Template {
  id            String         @id @default(cuid())
  workspaceId    String
  name           String
  type           TemplateType
  status         TemplateStatus @default(DRAFT)
  body           Json
  compatibility  Json?
  usageCount     Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  workspace      Workspace     @relation(fields: [workspaceId], references: [id])
  campaigns      Campaign[]
}

model ChatbotFlow {
  id              String        @id @default(cuid())
  workspaceId      String
  name             String
  description      String?
  status           FlowStatus   @default(DRAFT)
  version          Int          @default(1)
  settings         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  workspace        Workspace    @relation(fields: [workspaceId], references: [id])
  nodes            ChatbotNode[]
  edges            ChatbotEdge[]
  runs             ChatbotRun[]
}

model ChatbotNode {
  id            String       @id @default(cuid())
  chatbotFlowId String
  type          FlowNodeType
  label         String
  config        Json
  positionX     Float
  positionY     Float
  flow          ChatbotFlow  @relation(fields: [chatbotFlowId], references: [id])
}

model ChatbotEdge {
  id            String       @id @default(cuid())
  chatbotFlowId String
  sourceNodeId  String
  targetNodeId  String
  condition     Json?
  flow          ChatbotFlow  @relation(fields: [chatbotFlowId], references: [id])
}

model ChatbotRun {
  id            String      @id @default(cuid())
  chatbotFlowId String
  contactId     String?
  inboxThreadId String?
  status        String
  state         Json?
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
  flow          ChatbotFlow @relation(fields: [chatbotFlowId], references: [id])
}

model AutoresponderRule {
  id            String     @id @default(cuid())
  workspaceId    String
  name           String
  priority       Int       @default(0)
  triggerConfig  Json
  actionConfig   Json
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
}

model FallbackRule {
  id             String     @id @default(cuid())
  workspaceId     String
  name            String
  triggerConfig   Json
  strategyConfig  Json
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
}

model MessageLog {
  id                String           @id @default(cuid())
  workspaceId        String
  whatsappAccountId  String?
  contactId          String?
  inboxThreadId      String?
  campaignId         String?
  direction          MessageDirection
  status             MessageStatus
  providerMessageId  String?
  providerPayload    Json?
  content            Json
  failureReason      String?
  createdAt          DateTime        @default(now())
  workspace          Workspace       @relation(fields: [workspaceId], references: [id])
  whatsappAccount    WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])
  contact            Contact?        @relation(fields: [contactId], references: [id])
}

model InboxThread {
  id                String            @id @default(cuid())
  workspaceId       String
  whatsappAccountId String?
  contactId         String?
  assignedUserId    String?
  status            InboxThreadStatus @default(OPEN)
  unreadCount       Int               @default(0)
  lastMessageAt     DateTime?
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  workspace         Workspace         @relation(fields: [workspaceId], references: [id])
  whatsappAccount   WhatsappAccount?  @relation(fields: [whatsappAccountId], references: [id])
  contact           Contact?          @relation(fields: [contactId], references: [id])
  assignedUser      User?             @relation("AssignedThreads", fields: [assignedUserId], references: [id])
  messages          InboxMessage[]
}

model InboxMessage {
  id            String        @id @default(cuid())
  inboxThreadId String
  direction     MessageDirection
  status        MessageStatus
  content       Json
  providerMeta  Json?
  createdAt     DateTime      @default(now())
  thread        InboxThread   @relation(fields: [inboxThreadId], references: [id])
}

model ApiKey {
  id            String        @id @default(cuid())
  workspaceId    String?
  userId         String?
  name           String
  keyPrefix      String
  hashedKey      String
  scopes         ApiKeyScope[]
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  workspace      Workspace?    @relation(fields: [workspaceId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])
}

model WebhookLog {
  id            String    @id @default(cuid())
  workspaceId   String?
  direction     String
  targetUrl     String?
  statusCode    Int?
  signatureValid Boolean?
  payload       Json
  createdAt     DateTime  @default(now())
}

model ActivityLog {
  id            String    @id @default(cuid())
  workspaceId   String?
  userId        String?
  action        String
  subjectType   String
  subjectId     String
  metadata      Json?
  createdAt     DateTime  @default(now())
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
  user          User?      @relation(fields: [userId], references: [id])
}

model AuditLog {
  id            String    @id @default(cuid())
  workspaceId   String?
  userId        String?
  action        String
  subjectType   String
  subjectId     String
  metadata      Json?
  ipAddress     String?
  createdAt     DateTime  @default(now())
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
  user          User?      @relation(fields: [userId], references: [id])
}

model ImportJob {
  id            String       @id @default(cuid())
  workspaceId   String
  status        ImportStatus @default(PENDING)
  fileUrl       String?
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspace     Workspace    @relation(fields: [workspaceId], references: [id])
}

model ExportJob {
  id            String       @id @default(cuid())
  workspaceId   String
  status        ExportStatus @default(PENDING)
  fileUrl       String?
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspace     Workspace    @relation(fields: [workspaceId], references: [id])
}

model BillingEvent {
  id             String       @id @default(cuid())
  organizationId String
  type           String
  amount         Decimal?     @db.Decimal(12, 2)
  currency       String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Notification {
  id            String     @id @default(cuid())
  workspaceId   String
  type          String
  title         String
  body          String
  metadata      Json?
  readAt        DateTime?
  createdAt     DateTime   @default(now())
  workspace     Workspace  @relation(fields: [workspaceId], references: [id])
}
