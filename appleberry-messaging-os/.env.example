NODE_ENV=production

POSTGRES_DB=appleberry_messaging_os
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password

DATABASE_URL=postgresql://postgres:replace-with-strong-db-password@localhost:5432/appleberry_messaging_os?schema=public
DIRECT_URL=postgresql://postgres:replace-with-strong-db-password@localhost:5432/appleberry_messaging_os?schema=public
REDIS_URL=redis://localhost:6379

WEB_PORT=3000
API_PORT=4000
API_PREFIX=v1
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
COOKIE_SECRET=replace-this
ENCRYPTION_KEY=replace-with-32-byte-key
WHATSAPP_WEB_SESSION_ROOT=.appleberry-wa-web
CHROME_EXECUTABLE_PATH=

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=appleberry
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_FORCE_PATH_STYLE=true

DEFAULT_PLATFORM_OWNER_EMAIL=owner@appleberry.local
DEFAULT_PLATFORM_OWNER_PASSWORD=ChangeMe123!
