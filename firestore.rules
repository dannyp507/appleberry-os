rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuthenticated();
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "foodbrus@gmail.com" ||
         (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
          (get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'owner')));
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.owner_user_id == request.auth.uid);
      allow delete: if false;
    }

    match /repair_status_options/{statusId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /repair_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    match /customers/{customerId} {
      allow get: if true;
      allow list: if isStaff();
      allow create, update: if isStaff() &&
        request.resource.data.first_name is string && request.resource.data.first_name.size() > 0;
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow get: if true;
      allow list: if isStaff();
      allow create, update: if isStaff() &&
        request.resource.data.name is string &&
        request.resource.data.stock is number;
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow get: if true;
      allow list: if isStaff();
      allow create: if isStaff() &&
        request.resource.data.total_amount is number &&
        request.resource.data.profit is number;

      match /items/{itemId} {
        allow get, list: if true;
        allow create: if isStaff();
      }
    }

    match /sale_items/{itemId} {
      allow read: if isStaff();
      allow create: if isStaff();
    }

    match /repairs/{repairId} {
      allow read: if isStaff();
      allow create, update: if isStaff() &&
        request.resource.data.customer_id is string &&
        request.resource.data.device_name is string &&
        request.resource.data.status_id is string;

      match /history/{historyId} {
        allow read: if isStaff();
        allow create: if isStaff() &&
          request.resource.data.repair_id == repairId &&
          request.resource.data.changed_by == request.auth.uid;
      }

      match /items/{itemId} {
        allow read: if isStaff();
        allow create, update, delete: if isStaff();
      }
    }

    match /profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        (request.resource.data.role == 'staff' || request.resource.data.role == 'owner' || isAdmin());
      allow update: if isAdmin() ||
        (request.auth.uid == profileId && request.resource.data.role == resource.data.role) ||
        (isAuthenticated() &&
          resource.data.email is string &&
          request.auth.token.email == resource.data.email &&
          request.resource.data.role == resource.data.role);
    }

    match /staff_invites/{inviteId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isAuthenticated() &&
          resource.data.email is string &&
          request.auth.token.email == resource.data.email);
    }

    match /marketing_templates/{templateId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /marketing_campaigns/{campaignId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /marketing_segments/{segmentId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /marketing_automations/{automationId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /marketing_deliveries/{deliveryId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /stock_takes/{entryId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /purchase_orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /inventory_transfers/{transferId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isStaff();
      allow create, update: if isStaff() &&
        request.resource.data.title is string &&
        request.resource.data.amount is number &&
        request.resource.data.category is string;
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow get: if true;
      allow list: if isStaff();
      allow write: if isAdmin();
    }
  }
}
